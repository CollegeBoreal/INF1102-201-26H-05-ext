$notebook = @{
    cells = @(
        @{
            cell_type = "markdown"
            metadata = @{}
            source = @(
                "# Rapport Monitoring Web`n",
                "`n",
                "**Ătudiant :** GACEM OUAIL  `n",
                "**Matricule :** 300148094  `n",
                "**Cours :** INF1102"
            )
        },
        @{
            cell_type = "markdown"
            metadata = @{}
            source = @(
                "## Objectif`n",
                "`n",
                "Ce projet vĂŠrifie la disponibilitĂŠ de plusieurs sites web et mesure les temps de rĂŠponse."
            )
        },
        @{
            cell_type = "code"
            execution_count = $null
            metadata = @{}
            outputs = @()
            source = @(
                "sites = ['google.com', 'github.com', 'youtube.com', 'wikipedia.org', 'stackoverflow.com']`n",
                "print('Sites monitorĂŠs :', sites)"
            )
        },
        @{
            cell_type = "code"
            execution_count = $null
            metadata = @{}
            outputs = @()
            source = @(
                "import requests`n",
                "import time`n",
                "`n",
                "resultats = []`n",
                "`n",
                "for site in sites:`n",
                "    try:`n",
                "        start = time.time()`n",
                "        requests.get('https://' + site, timeout=5)`n",
                "        end = time.time()`n",
                "`n",
                "        resultats.append({`n",
                "            'site': site,`n",
                "            'status': 'OK',`n",
                "            'temps_reponse_ms': round((end - start) * 1000, 2)`n",
                "        })`n",
                "    except:`n",
                "        resultats.append({`n",
                "            'site': site,`n",
                "            'status': 'DOWN',`n",
                "            'temps_reponse_ms': None`n",
                "        })`n",
                "`n",
                "resultats"
            )
        },
        @{
            cell_type = "code"
            execution_count = $null
            metadata = @{}
            outputs = @()
            source = @(
                "import json`n",
                "`n",
                "with open('output/rapport.json', 'w') as f:`n",
                "    json.dump(resultats, f, indent=4)`n",
                "`n",
                "print('Fichier JSON gĂŠnĂŠrĂŠ : output/rapport.json')"
            )
        },
        @{
            cell_type = "markdown"
            metadata = @{}
            source = @(
                "## Conclusion`n",
                "`n",
                "- Les sites sont vĂŠrifiĂŠs automatiquement`n",
                "- Les temps de rĂŠponse sont mesurĂŠs`n",
                "- Un fichier JSON est gĂŠnĂŠrĂŠ"
            )
        }
    )
    metadata = @{
        kernelspec = @{
            display_name = "Python 3"
            language = "python"
            name = "python3"
        }
        language_info = @{
            name = "python"
        }
    }
    nbformat = 4
    nbformat_minor = 2
}

$notebook | ConvertTo-Json -Depth 10 | Set-Content -Path "RAPPORT.ipynb" -Encoding utf8
